# Minimal Talos-authored Python syntax (T778). Project-licensed; not derived from GNU nano's GPL files.
syntax "python" "\.py$"
color green "\<(and|as|assert|async|await|break|class|continue|def|del|elif|else|except|finally|for|from|global|if|import|in|is|lambda|match|nonlocal|not|or|pass|raise|return|try|while|with|yield)\>"
color cyan "\<(True|False|None|self|cls)\>"
color yellow "\<[0-9][0-9_]*(\.[0-9_]+)?([eE][+-]?[0-9]+)?[jJ]?\>"
color brightcyan "\<(print|len|range|str|int|float|list|dict|set|tuple|open|type|isinstance|super|enumerate|zip|map|filter)\>"
color magenta ""[^"]*""
color magenta "'[^']*'"
color brightblack "#.*$"
