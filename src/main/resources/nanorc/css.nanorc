# Minimal Talos-authored CSS syntax (T778). Project-licensed; not derived from GNU nano's GPL files.
syntax "css" "\.css$"
color brightcyan "^[[:space:]]*[.#]?[A-Za-z][A-Za-z0-9_-]*"
color green "[A-Za-z-]+[[:space:]]*:"
color yellow "\<-?[0-9]+(\.[0-9]+)?(px|em|rem|vh|vw|%|s|ms)?\>"
color magenta ""[^"]*""
color magenta "'[^']*'"
color cyan "#[0-9A-Fa-f]{3,8}\>"
color brightblack "/\*.*\*/"
