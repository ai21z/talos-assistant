# Minimal Talos-authored YAML syntax (T778). Project-licensed; not derived from GNU nano's GPL files.
syntax "yaml" "\.(yaml|yml)$"
color brightcyan "^[[:space:]]*[A-Za-z0-9_.-]+[[:space:]]*:"
color cyan "\<(true|false|null|yes|no|on|off)\>"
color yellow "\<-?[0-9]+(\.[0-9]+)?\>"
color magenta ""[^"]*""
color magenta "'[^']*'"
color green "^[[:space:]]*- "
color brightblack "#.*$"
